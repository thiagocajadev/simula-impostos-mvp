root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
